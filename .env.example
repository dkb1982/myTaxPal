# TaxEstimate API Configuration
# Copy to .env and adjust values for your environment.
# All variables use the TAX_ESTIMATOR_ prefix.

# --- Server ---
TAX_ESTIMATOR_HOST=0.0.0.0
TAX_ESTIMATOR_PORT=8000
TAX_ESTIMATOR_DEBUG=true

# --- Logging ---
# DEBUG, INFO, WARNING, ERROR, CRITICAL
TAX_ESTIMATOR_LOG_LEVEL=INFO

# --- CORS ---
# JSON list of allowed origins (empty = no CORS)
TAX_ESTIMATOR_CORS_ORIGINS=["http://localhost:8000"]
TAX_ESTIMATOR_CORS_ALLOW_CREDENTIALS=false
TAX_ESTIMATOR_CORS_ALLOW_METHODS=["GET","POST","OPTIONS"]
TAX_ESTIMATOR_CORS_ALLOW_HEADERS=["Content-Type","Authorization","X-Request-Id"]

# --- Rate Limiting ---
TAX_ESTIMATOR_RATE_LIMIT_ENABLED=true
TAX_ESTIMATOR_RATE_LIMIT_REQUESTS_PER_MINUTE=60
TAX_ESTIMATOR_RATE_LIMIT_TRUST_PROXY=false
TAX_ESTIMATOR_RATE_LIMIT_TRUSTED_PROXY_IPS=[]
TAX_ESTIMATOR_RATE_LIMIT_WINDOW_SECONDS=60

# --- Security Headers ---
TAX_ESTIMATOR_SECURITY_HEADERS_ENABLED=true
TAX_ESTIMATOR_HSTS_MAX_AGE=31536000
TAX_ESTIMATOR_MAX_REQUEST_BODY_BYTES=1048576
# Leave unset to use the default CSP policy:
# TAX_ESTIMATOR_CSP_POLICY=

# --- Rules ---
# Leave unset to use the default rules directory:
# TAX_ESTIMATOR_RULES_DIR=
